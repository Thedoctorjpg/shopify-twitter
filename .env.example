# Shopify
SHOPIFY_ACCESS_TOKEN=your_access_token_here
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# X / Twitter (for twitter-api-v2 with OAuth 1.0a User Context - recommended for posting)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Optional: Bearer for read-only v2 or app-only
TWITTER_BEARER_TOKEN=your_bearer_token_optional

# Server
PORT=3000
NODE_ENV=development

# Optional: For frontend later / CORS
FRONTEND_URL=http://localhost:5173

# Webhook Configuration (IMPORTANT for remote hosting)
# Set this to your public HTTPS URL when deployed (no trailing slash)
# Example: https://shopify-x-integration-xxxxx.onrender.com
# Example for Google Cloud Run: https://your-service-xxx-uc.a.run.app
WEBHOOK_BASE_URL=

# WordPress Integration (optional)
# Create an Application Password in WP Admin > Users > Profile
WORDPRESS_SITE_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your-wp-username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Forward events to remote / Google-hosted endpoints (optional)
# Comma-separated list of HTTPS URLs that will receive POSTs with the full payload
# Perfect for: Google Apps Script Web Apps, Cloud Functions, your own remote site, n8n, Zapier Catch Hook, etc.
# Example: https://script.google.com/macros/s/xxx/exec,https://your-google-cloud-function.run.app/webhook
EXTERNAL_WEBHOOK_URLS=

# ============================================
# Amazon Web Services (AWS) Hosting
# ============================================
# After deploying (App Runner / ECS), set your public URL here so webhooks know the real address.
# Example from AWS App Runner: https://abc123.us-west-2.awsapprunner.com
AWS_WEBHOOK_BASE_URL=

# ============================================
# eBay Integration
# ============================================
# Get credentials: https://developer.ebay.com/my/keys
# Use production for real store, sandbox for testing.
EBAY_ENV=production
EBAY_APP_ID=your-ebay-app-id
EBAY_APP_SECRET=your-ebay-app-secret
# User token for your own seller data (listings, orders). Generate via OAuth or developer tools.
EBAY_ACCESS_TOKEN=
EBAY_REFRESH_TOKEN=

# ============================================
# AliExpress / Alibaba Open Platform
# ============================================
# Sign up: https://open.aliexpress.com/ (or Alibaba Cloud Marketplace)
# Used for product search, details, and affiliate/dropshipping data.
ALIBABA_APP_KEY=your-alibaba-app-key
ALIBABA_APP_SECRET=your-alibaba-app-secret
ALIBABA_ACCESS_TOKEN=

# xAI Grok Imagine API (for image/video generation, product ads, virtual try-on, edits)
# Get key at https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Grok text for marketing copy generation (set to true to use Grok instead of templates)
USE_GROK_COPY=true

# Twitter Ads Account ID for full promotion (optional, requires Ads access)
TWITTER_ADS_ACCOUNT_ID=
