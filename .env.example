# Shopify
SHOPIFY_ACCESS_TOKEN=your_access_token_here
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# X / Twitter (for twitter-api-v2 with OAuth 1.0a User Context - recommended for posting)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Optional: Bearer for read-only v2 or app-only
TWITTER_BEARER_TOKEN=your_bearer_token_optional

# Server
PORT=3000
NODE_ENV=development

# Optional: For frontend later / CORS
FRONTEND_URL=http://localhost:5173
