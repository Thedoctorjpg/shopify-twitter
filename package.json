{
  "name": "shopify-x-integration",
  "version": "1.0.0",
  "description": "Shopify + X (Twitter) integration built with Grok. Real-time product/order webhooks, auto-tweeting, dashboards, and daily summaries.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:full": "concurrently \"npm run dev\" \"cd frontend && npm run dev\"",
    "test": "echo \"No tests yet\" && exit 0",
    "frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [
    "shopify",
    "ebay",
    "aliexpress",
    "twitter",
    "x",
    "integration",
    "webhooks",
    "cron",
    "ecommerce",
    "aws"
  ],
  "author": "Built with Grok",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1061.0",
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "openai": "^6.41.0",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
